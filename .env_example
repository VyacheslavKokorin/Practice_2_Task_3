# Пароль от пользователя ROOT внутри контейнера
DB_ROOT_PASSWORD=replace_with_strong_root_password

# Имя базы данных
DB_NAME=blog_db

# Имя пользователя базы данных
DB_USER=blog_user

# Пароль пользователя базы данных
DB_PASSWORD=replace_with_strong_user_password

# Имя контейнера базы данных
DB_HOST=db

# Секретный ключ для подписи JWT (длинная случайная строка)
JWT_SECRET=replace_with_long_random_secret

# Срок жизни токена
JWT_EXPIRES_IN=7d